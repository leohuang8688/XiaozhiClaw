# XiaoZhiClaw Environment Variables
# Copy this file to .env and fill in your actual values

# Volcengine Doubao API Credentials
# Get these from: https://console.volcengine.com/
DOUBAO_APP_ID=your_app_id_here
DOUBAO_ACCESS_TOKEN=your_access_token_here

# WebSocket Server Configuration
XIAOZHI_PORT=8080

# Optional: Doubao TTS Voice Type
# Default: zh_female_tianmei_moon_bigtts
# Other options: zh_female_shuangkuai_moon_bigtts, zh_male_yunqi_moon_bigtts
DOUBAO_VOICE_TYPE=zh_female_tianmei_moon_bigtts

# Optional: Audio Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_FRAME_DURATION=60
AUDIO_CHANNELS=1
